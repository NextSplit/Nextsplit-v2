NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Premium / Subscription ───────────────────────────────────────────────────
# Server-only flag (no NEXT_PUBLIC_ prefix — never inlined into the client
# bundle, council /council 2026-05-07 P1.3). Set to 'true' to enforce
# subscription tiers (production monetisation). Leave as 'false' for
# dev/testing — all features available to everyone.
# Vercel migration: rename existing NEXT_PUBLIC_PREMIUM_ENFORCED → PREMIUM_ENFORCED.
PREMIUM_ENFORCED=false

# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here
